
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id            String   @id
  name          String
  role          String?
  phoneNo       String?  @map("phone_no")
  emergencyNo   String?  @map("emergency_no")
  status        String?  @default("Active")
  type          String?  @default("Employee") // Employee, Contractor, Intern
  projectName   String?  @default("-")
  projectStatus String?  @default("Inactive") // Active, Inactive
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("employees")
}

model Salary {
  id         String   @id
  month      String
  emps       Int      @default(0)
  total      String?
  status     String?  @default("Draft")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("salaries")
}

model Leave {
  id         String   @id @default(uuid())
  name       String
  type       String
  days       Int      @default(1)
  dates      String?
  reason     String?
  status     String?  @default("Pending")
  attachments String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("leaves")
}

model Attendance {
  id         String   @id @default(uuid())
  name       String
  empId      String?  @map("emp_id")
  role       String?
  destination String?
  date       DateTime @db.Date
  checkIn    String?  @map("checkIn")
  checkOut   String?  @map("checkOut")
  breakTime  String?  @map("break_time")
  totalWorkingHrs String? @map("total_working_hrs")
  outTimeHrs String? @map("out_time_hrs")
  status     String?  @default("Present")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("attendance")
}

model Project {
  id              String   @id @default(uuid())
  projectNo       String?  @map("project_no")
  name            String
  description     String?  @db.Text
  client          String?
  clientId        String?  @map("client_id")
  clientRef       Client?  @relation(fields: [clientId], references: [id])
  status          String?  @default("Active")
  estimatedHours  Float?   @default(0) @map("estimated_hours")
  actualHours     Float?   @default(0) @map("actual_hours")
  billableHours   Float?   @default(0) @map("billable_hours")
  members         String?  @default("")       // Comma-separated names or IDs
  createdAt       DateTime @default(now()) @map("created_at")
  taskLists       TaskList[]
  queries         ProjectQuery[]
  attachments     ProjectAttachment[]
  tasks           Task[]
  estimations     Estimation[]

  @@map("projects")
}

model Client {
  id              String    @id @default(uuid())
  clientType      String?   @default("Direct") @map("client_type") // Direct, Agency, Agency Client
  parentAgencyId  String?   @map("parent_agency_id")
  parentAgency    Client?   @relation("AgencyClients", fields: [parentAgencyId], references: [id])
  agencyClients   Client[]  @relation("AgencyClients")
  name            String
  email           String?
  phone           String?
  company         String?
  address         String?
  status          String?   @default("Active")
  createdAt       DateTime  @default(now()) @map("created_at")
  projects        Project[]
  tasks           Task[]
  estimations     Estimation[]

  @@map("clients")
}

model Estimation {
  id              String   @id @default(uuid())
  estimationNo    String?  @map("estimation_no")
  taskName        String   @map("task_name")
  description     String?  @db.Text
  estimatedHours  Float    @default(0) @map("estimated_hours")
  client          String?
  clientId        String?  @map("client_id")
  clientRef       Client?  @relation(fields: [clientId], references: [id])
  projectId       String?  @map("project_id")
  projectRef      Project? @relation(fields: [projectId], references: [id])
  status          String?  @default("Pending") // Pending, Converted, Cancelled
  taskId          String?  @map("task_id")
  taskRef         Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("estimations")
}

model ProjectQuery {
  id          String   @id @default(uuid())
  queryId     String   @map("query_id")
  title       String
  description String?  @db.Text
  sentTo      String?  @map("sent_to")
  status      String?  @default("Open") // Open, In Progress, Closed
  solved      Boolean  @default(false)
  priority    String?  @default("Medium") // Low, Medium, High
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("project_queries")
}

model ProjectAttachment {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  uploadedBy  String   @map("uploaded_by")
  fileSize    String?  @map("file_size")
  fileUrl     String?  @map("file_url")
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("project_attachments")
}

model TaskList {
  id        String   @id @default(uuid())
  name      String
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("task_lists")
}

model Team {
  id         String   @id @default(uuid())
  name       String
  lead       String?
  members    Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("teams")
}

model Task {
  id          String   @id @default(uuid())
  taskNo      String?  @map("task_no")
  title       String
  description String?
  taskType    String?  @map("task_type")
  projectName String?  @map("project_name")
  projectId   String?  @map("project_id")
  projectRef  Project? @relation(fields: [projectId], references: [id])
  clientId    String?  @map("client_id")
  clientRef   Client?  @relation(fields: [clientId], references: [id])
  assignees   String?
  dueDate     DateTime?
  status      String?  @default("To Do")
  priority    String?  @default("Medium")
  tag         String?
  startDate   DateTime?
  endDate     DateTime?
  assignedDate DateTime?
  deliveredDate DateTime? @map("delivered_date")
  isBillable  Boolean  @default(false)
  estimatedHours Float?  @default(0) @map("estimated_hours")
  approvedHours Float?   @default(0)
  actualHours   Float?   @default(0)
  taskListId  String?
  taskList    TaskList? @relation(fields: [taskListId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")
  attachments String?

  comments    Comment[]
  estimations Estimation[]
  workLogs    WorkLog[]

  @@map("tasks")
}


model Bug {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String?  @default("Open")
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("bugs")
}

model Comment {
  id        String   @id @default(uuid())
  taskId    String
  text      String
  author    String
  likes     Int      @default(0)
  reactions Json?    @default("{}")
  parentId  String?
  createdAt DateTime @default(now()) @map("created_at")

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  @@map("comments")
}

model User {
  id           String   @id @default(uuid())
  firstName    String?
  lastName     String?
  fullName     String?
  email        String?  @unique
  password     String?
  phoneNo      String?  @map("phone_no")
  empId        String?  @unique @map("emp_id")
  designation  String?
  profileImage String?  @map("profile_image")
  role         String?  @default("User")
  status       String?  @default("Active")
  createdAt    DateTime @default(now()) @map("created_at")

  workLogs     WorkLog[]

  @@map("users")
}

model WorkLog {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logDate     DateTime @db.Date @map("log_date")
  hoursWorked Float    @map("hours_worked")
  description String?  @db.Text
  isBilled    Boolean  @default(false) @map("is_billed")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("work_logs")
}




model RolePermission {
  id        String   @id @default(uuid())
  role      String   @unique
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("role_permissions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id") // the user who receives the notification
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notifications")
}
