
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl removed: port 5432 is blocked in this network environment
  // Use Supabase Dashboard SQL Editor to run schema changes manually
}

// Unused models removed (Employee, Salary, Leave, Attendance)

model Project {
  id              String   @id @default(uuid())
  projectNo       String?  @map("project_no")
  name            String
  description     String?  @db.Text
  client          String?
  clientId        String?  @map("client_id")
  clientRef       Client?  @relation(fields: [clientId], references: [id])
  status          String?  @default("Active")
  estimatedHours  Float?   @default(0) @map("estimated_hours")
  actualHours     Float?   @default(0) @map("actual_hours")
  billableHours   Float?   @default(0) @map("billable_hours")
  members         String?  @default("")       // Comma-separated names or IDs
  createdAt       DateTime @default(now()) @map("created_at")
  taskLists       TaskList[]
  queries         ProjectQuery[]
  attachments     ProjectAttachment[]
  tasks           Task[]
  estimations     Estimation[]

  @@map("projects")
}

model Client {
  id              String    @id @default(uuid())
  clientType      String?   @default("Direct") @map("client_type") // Direct, Agency, Agency Client
  parentAgencyId  String?   @map("parent_agency_id")
  parentAgency    Client?   @relation("AgencyClients", fields: [parentAgencyId], references: [id])
  agencyClients   Client[]  @relation("AgencyClients")
  name            String
  email           String?
  phone           String?
  company         String?
  address         String?
  status          String?   @default("Active")
  createdAt       DateTime  @default(now()) @map("created_at")
  projects        Project[]
  tasks           Task[]
  estimations     Estimation[]

  @@map("clients")
}

model Estimation {
  id              String   @id @default(uuid())
  estimationNo    String?  @map("estimation_no")
  taskName        String   @map("task_name")
  description     String?  @db.Text
  estimatedHours  Float    @default(0) @map("estimated_hours")
  client          String?
  clientId        String?  @map("client_id")
  clientRef       Client?  @relation(fields: [clientId], references: [id])
  projectId       String?  @map("project_id")
  projectRef      Project? @relation(fields: [projectId], references: [id])
  status          String?  @default("Pending") // Pending, Converted, Cancelled
  taskId          String?  @map("task_id")
  taskRef         Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("estimations")
}

model ProjectQuery {
  id          String   @id @default(uuid())
  queryId     String   @map("query_id")
  title       String
  description String?  @db.Text
  sentToId    String?  @map("sent_to")
  status      String?  @default("Open") // Open, In Progress, Closed
  solved      Boolean  @default(false)
  priority    String?  @default("Medium") // Low, Medium, High
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("project_queries")
}

model ProjectAttachment {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  uploadedBy  String   @map("uploaded_by")
  fileSize    String?  @map("file_size")
  fileUrl     String?  @map("file_url")
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("project_attachments")
}

model TaskList {
  id          String   @id @default(uuid())
  name        String
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  isFavorite  Boolean?  @default(false) @map("is_favorite")
  favoritedBy String?   @map("favorited_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("task_lists")
}

model Team {
  id          String   @id @default(uuid())
  name        String
  role        String?  @default("Employee")
  designation String?
  lead        String?
  members     Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("teams")
}

model Task {
  id          String   @id @default(uuid())
  taskNo      String?  @map("task_no")
  title       String
  description String?
  taskType    String?  @map("task_type")
  projectId   String?  @map("project_id")
  projectRef  Project? @relation(fields: [projectId], references: [id])
  clientId    String?  @map("client_id")
  clientRef   Client?  @relation(fields: [clientId], references: [id])
  assignees   String?  // Comma-separated User UUIDs
  dueDate     DateTime?
  status      String?  @default("To Do")
  priority    String?  @default("Medium")
  tag         String?
  assignedDate DateTime?
  deliveredDate DateTime? @map("delivered_date")
  isBillable  Boolean  @default(false)
  billableAmount Float? @default(0) @map("billable_amount")
  estimatedHours Float?  @default(0) @map("estimated_hours")
  approvedHours Float?   @default(0)
  actualHours   Float?   @default(0)
  employeeHours Float?   @default(0) @map("employee_hours")
  taskListId  String?
  taskList    TaskList? @relation(fields: [taskListId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")
  attachments String?
  createdBy   String?  @map("created_by")
  creatorId   String?  @map("creator_id")

  recurringTemplateId String?   @map("recurring_template_id")
  recurringTemplate   Task?     @relation("RecurringInstances", fields: [recurringTemplateId], references: [id], onDelete: Cascade)
  recurringInstances  Task[]    @relation("RecurringInstances")
  recurrenceFrequency String?   @map("recurrence_frequency")
  recurrenceDetail    String?   @map("recurrence_detail")
  nextOccurrence      DateTime? @map("next_occurrence")
  lastOccurrence      DateTime? @map("last_occurrence")

  comments    Comment[]
  estimations Estimation[]
  workLogs    WorkLog[]

  parentId     String?   @map("parent_id")
  parentTask   Task?     @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks     Task[]    @relation("SubTasks")

  @@map("tasks")
}


// Unused Bug model removed

model Comment {
  id        String   @id @default(uuid())
  taskId    String
  text      String
  authorId  String   @map("author")
  user      User     @relation(fields: [authorId], references: [id])
  likes     Int      @default(0)
  reactions Json?    @default("{}")
  parentId  String?
  createdAt DateTime @default(now()) @map("created_at")

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  @@map("comments")
}

model User {
  id           String   @id @default(uuid())
  firstName    String?
  lastName     String?
  fullName     String?
  email        String?  @unique
  password     String?
  phoneNo      String?  @map("phone_no")
  emergencyNo  String?  @map("emergency_no")
  type         String?  @default("Employee") // Employee, Contractor, Intern
  projectStatus String? @default("Inactive") // Active, Inactive
  empId        String?  @unique @map("emp_id")
  designation  String?
  profileImage String?  @map("profile_image")
  role         String?  @default("User")
  status       String?  @default("Active")
  fcmToken     String?  @map("fcm_token")
  createdAt    DateTime @default(now()) @map("created_at")

  workLogs     WorkLog[]
  comments     Comment[]
  notifications Notification[]

  @@map("users")
}

model WorkLog {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logDate     DateTime @db.Date @map("log_date")
  hoursWorked Float    @map("hours_worked")
  description String?  @db.Text
  isBilled    Boolean  @default(false) @map("is_billed")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("work_logs")
}




model RolePermission {
  id        String   @id @default(uuid())
  role      String   @unique
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("role_permissions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id") // the user who receives the notification
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notifications")
}

model Report {
  id                 String    @id @default(uuid())
  taskNo             String?   @map("task_no")
  title              String
  companyName        String?   @map("company_name")
  projectName        String?   @map("project_name")
  projectId          String?   @map("project_id")
  clientId           String?   @map("client_id")
  assignees          String?   // Comma-separated User UUIDs
  billableHours      Float     @default(0.0) @map("billable_hours")
  alreadyBilled      Float     @default(0.0) @map("already_billed")
  deliveredDate      DateTime? @map("delivered_date")
  createdAt          DateTime  @default(now()) @map("created_at")

  @@map("reports")
}

